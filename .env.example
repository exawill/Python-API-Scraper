# ══════════════════════════════════════════════════════════════════════
#  .env — Secure Runtime Environment Configuration
#  DO NOT commit this file to version control.
#  Add `.env` to your .gitignore immediately.
# ══════════════════════════════════════════════════════════════════════

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_PLACEHOLDER

# Discord Webhook URL (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_PLACEHOLDER
